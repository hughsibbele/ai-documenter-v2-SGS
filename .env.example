# AI Documenter v2 — env template
#
# This file is the CANONICAL source of truth for which env vars the app reads.
# If you add a new env var in code, add it here in the same PR. If you rename
# one on Vercel, rename it here too. Project policy is "`.env.example` is
# canonical; Vercel and code conform to it."
#
# Local dev: copy this file to .env.local and fill in values.
# Vercel:    set each var on the project's Settings → Environment Variables.

# ---- Supabase ---------------------------------------------------------------
# Project: ai-documenter-v2 (id: exuqndgtwqwezbmfansr, region: us-east-1)
NEXT_PUBLIC_SUPABASE_URL=https://exuqndgtwqwezbmfansr.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_3UGc-F5iXCfbKS4mlJ_XSQ_ptHkchoa
# Server-only. Pull from Supabase dashboard → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Anonymizer salt (SHARED ECOSYSTEM-WIDE) -------------------------------
# Per integration-contract.md §2: this MUST be byte-identical across
# super-grader, AI Documenter v2, Handwritten Helper, Oral Examiner v2, and
# Harkness v2. All projects use this same var name.
# To set up: pull super-grader's value with `vercel env pull` from the
# super-grader project, copy it here verbatim. Don't generate a new one —
# a fresh salt silently produces different anon_tokens, breaking cross-tool join.
SUPER_GRADER_SALT=

# ---- Canvas token at-rest encryption (teacher-admin) ------------------------
# 32 random bytes, base64-encoded. Generate ONCE per project; rotation requires
# decrypting + re-encrypting every teachers.canvas_token_encrypted row.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CANVAS_TOKEN_ENC_KEY=

# ---- App base URL (used by Canvas install + outbound webhooks) -------------
# Origin of this deployment. The install action embeds this in the Canvas
# assignment description's reflection card; the outbound super-grader
# webhook uses it to compose links.detail_url.
#
# Local dev: http://localhost:3000  ·  Production: the deployed app URL.
NEXT_PUBLIC_APP_URL=

# Legacy name for the same value (pre-merge "student form" host). M4.3
# transition: code reads NEXT_PUBLIC_APP_URL first and falls back to this
# for one cycle. Drop this entry once every deploy environment has been
# migrated to the new name.
NEXT_PUBLIC_STUDENT_FORM_URL=https://ai-documenter-v2-student-form.vercel.app

# ---- Admin bootstrap (teacher-admin only) ----------------------------------
# Email of the first admin. If the `admins` table is empty, this user gets
# auto-inserted on their first /admin visit. After bootstrap, additional
# admins are granted via /admin/admins by an existing admin.
INITIAL_ADMIN_EMAIL=
# Optional: only emails on this domain can be granted admin. Leave unset to
# allow any email an existing admin types.
ADMIN_EMAIL_DOMAIN=episcopalhighschool.org

# ---- Google OAuth (both apps) -----------------------------------------------
# Create a Web OAuth client in https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://exuqndgtwqwezbmfansr.supabase.co/auth/v1/callback
# Configure Supabase Auth → Providers → Google with these values.
# `hd` parameter is set in the sign-in call (see app code), restricts to
# @episcopalhighschool.org Google Workspace.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Gemini (student-form, server-side only) --------------------------------
# Hugh's personal, EHS-paid key. Same key is used by super-grader and
# Handwritten Helper.
GEMINI_API_KEY=

# Per-teacher daily call cap (defaults to 500 if unset). Phase F rate limit
# bucket — protects against runaway costs from a single classroom.
GEMINI_DEFAULT_DAILY_CAP=500

# ---- Cron auth (Vercel scheduled functions) --------------------------------
# Vercel automatically attaches `Authorization: Bearer ${CRON_SECRET}` to
# scheduled requests. The /api/cron/* routes verify this header.
# Generate: openssl rand -hex 32
CRON_SECRET=

# ---- Sentry (optional — leave blank to disable error reporting) -------------
SENTRY_DSN=
# Browser DSN — must be public-prefixed since it ships to the client bundle.
NEXT_PUBLIC_SENTRY_DSN=

# ---- super-grader peer integration (student-form) ---------------------------
# Bearer token super-grader sends when calling our GET /api/super-grader/result
# endpoint. SHARED VALUE with super-grader (where it's named AI_DOCUMENTER_API_TOKEN
# there too — same var name, same value).
AI_DOCUMENTER_API_TOKEN=

# Base URL of the super-grader deployment. Code appends /api/ingest/ai_documenter.
# When super-grader isn't deployed, leave blank — the webhook silently no-ops.
SUPER_GRADER_API_URL=https://super-grader.vercel.app

# Bearer we present on outbound POST to <SUPER_GRADER_API_URL>/api/ingest/ai_documenter.
# SHARED VALUE with super-grader (where it's named AI_DOCUMENTER_INGEST_TOKEN
# — asymmetric naming on purpose: each side names after who it's talking to).
SUPER_GRADER_INGEST_TOKEN=
